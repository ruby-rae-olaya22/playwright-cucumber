{
    "default":{
        "paths":[
            "features/**/*.feature",
            "features/*.feature"
        ],
        "require":[
            "src/step-definitions/**/*.ts",
            "src/step-definitions/*.ts"
        ],
        "requireModule":[ 
            "ts-node/register" 
        ],
        "formatOptions":{
            "snippetInterface":"async-await"
        },
        "publishQuiet":true,
        "dryRun":false,
        "format":[
            "progress",
            "json:reports/cucumber-report.json",
            "html:reports/cucumber-report.html"
        ]
    }
}