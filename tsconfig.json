{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "rootDir": "."
  },
  "include": ["src/**/*", "features/**/*"],
  "exclude": [
    "node_modules",
    "playwright-report",
    "test-results"
  ]
}